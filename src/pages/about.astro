---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Pen N" description="About Pen N">
  <!-- Hero Section -->
  <section class="about-hero fade-up">
    <p class="eyebrow">About</p>
    <h1>A practical collaborator with strong frontend instincts.</h1>
    <div class="hero-content">
      <p>
        I enjoy partnering with teams that care deeply about user outcomes and engineering craft.
        Most of my recent projects involve translating rough requirements into polished, performant interfaces.
      </p>
      <p>
        My workflow blends design critique, rapid prototyping, and clear handoff. I prioritize clarity in both code
        and communication so teams can iterate confidently.
      </p>
    </div>
  </section>

  <!-- Values Section -->
  <section class="values-section section-block">
    <div class="grid two">
      <div class="value-card fade-up">
        <div class="card-icon">⚡</div>
        <h2>How I work</h2>
        <p>Structure uncertainty quickly with prototypes and clear constraints.</p>
        <p>Use design systems and shared patterns to keep delivery consistent.</p>
        <p>Favor incremental, testable improvements over risky rewrites.</p>
      </div>
      <div class="value-card fade-up">
        <div class="card-icon">🎯</div>
        <h2>What I value</h2>
        <p>Calm and legible interfaces that respect user attention.</p>
        <p>Codebases teams can safely maintain six months later.</p>
        <p>Cross-functional collaboration without unnecessary process overhead.</p>
      </div>
    </div>
  </section>

  <style>
    /* About Hero Styling */
    .about-hero {
      padding: var(--space-2xl) 0 var(--space-xl);
      max-width: 76ch;
      position: relative;
      overflow: hidden;
    }

    .about-hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: 
        radial-gradient(circle at 20% 20%, var(--accent-soft) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, var(--accent-secondary-soft) 0%, transparent 50%);
      opacity: 0.4;
      z-index: -1;
      animation: hero-glow 8s ease-in-out infinite alternate;
    }

    .about-hero .eyebrow {
      background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-shadow: 0 0 20px var(--accent-soft);
      margin-bottom: var(--space-md);
    }

    .about-hero h1 {
      background: linear-gradient(135deg, var(--text), var(--accent), var(--accent-secondary));
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 30px var(--accent-soft);
      position: relative;
      margin-bottom: var(--space-lg);
    }

    .about-hero h1::after {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent-secondary), var(--accent));
      animation: scanline 3s ease-in-out infinite;
    }

    .hero-content p {
      color: var(--text-secondary);
      font-size: clamp(1rem, 2vw, 1.15rem);
      position: relative;
      padding-left: var(--space-sm);
      margin-bottom: var(--space-md);
    }

    .hero-content p::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--accent), var(--accent-secondary));
      border-radius: 1px;
    }

    /* Value Cards Styling */
    .value-card {
      background: color-mix(in srgb, var(--surface) 92%, transparent);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: var(--space-lg);
      box-shadow: 
        0 18px 40px -35px rgba(15, 25, 36, 0.45),
        0 0 20px -5px var(--accent-soft);
      position: relative;
      transition: all var(--transition-normal) ease;
    }

    .value-card::before {
      content: '';
      position: absolute;
      top: -1px;
      left: -1px;
      right: -1px;
      bottom: -1px;
      border-radius: var(--radius);
      background: linear-gradient(45deg, var(--accent), var(--accent-secondary), var(--accent));
      opacity: 0;
      transition: opacity var(--transition-normal) ease;
      z-index: -1;
    }

    .value-card:hover {
      transform: translateY(-4px);
      box-shadow: 
        0 25px 50px -25px rgba(15, 25, 36, 0.6),
        0 0 30px -10px var(--accent-soft);
    }

    .value-card:hover::before {
      opacity: 0.15;
    }

    .card-icon {
      font-size: 2rem;
      margin-bottom: var(--space-sm);
      filter: drop-shadow(0 0 10px var(--accent-soft));
    }

    .value-card h2 {
      margin-bottom: var(--space-md);
    }

    .value-card p {
      color: var(--text-secondary);
      margin-bottom: var(--space-sm);
      line-height: 1.6;
    }

    .values-section {
      padding-top: var(--space-xl);
    }

    /* Animation keyframes */
    @keyframes scanline {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 1; }
    }

    @keyframes hero-glow {
      0% { opacity: 0.3; }
      100% { opacity: 0.6; }
    }

    /* Accessibility: reduce motion for users who prefer it */
    @media (prefers-reduced-motion: reduce) {
      .about-hero::before,
      .about-hero h1::after,
      .value-card {
        animation: none !important;
        transition: none !important;
      }
    }

    /* Responsive design */
    @media (max-width: 820px) {
      .about-hero {
        padding-top: var(--space-xl);
      }

      .values-section .grid.two {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
