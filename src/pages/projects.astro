---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = [
  {
    title: "Client Portal Refresh",
    description: "Modernized legacy pages into a cohesive, accessible portal while reducing render cost and support burden.",
    stack: "Astro, TypeScript, REST API",
    href: "#",
  },
  {
    title: "Booking Funnel Optimization",
    description: "Introduced UX improvements and instrumentation that improved conversion quality and reduced abandonment.",
    stack: "React, A/B testing, Analytics",
    href: "#",
  },
  {
    title: "Knowledge Base Redesign",
    description: "Reworked content architecture and search behavior to cut average support resolution time.",
    stack: "Content modeling, Algolia",
    href: "#",
  },
];
---

<BaseLayout title="Projects | Pen N" description="Project highlights and case studies">
  <section style="max-width:72ch;">
    <p class="eyebrow fade-up">Projects</p>
    <h1 class="fade-up">Selected work</h1>
    <p class="fade-up">
      A short set of projects where I contributed to product direction, interaction design,
      and robust frontend implementation.
    </p>
  </section>

  <section class="grid section-block">
    {projects.map((project) => <ProjectCard {...project} />)}
  </section>
</BaseLayout>
