---
import BaseLayout from "../layouts/BaseLayout.astro";

const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith("/") ? baseRaw : `${baseRaw}/`;
---

<BaseLayout title="Resume | Pen N" description="Resume and experience overview">
  <section class="grid" style="max-width:72ch;gap:1.2rem;">
    <p class="eyebrow fade-up">Resume</p>
    <h1 class="fade-up">Experience overview</h1>
    <p class="fade-up">Download the full resume for role details, measurable outcomes, and technology history.</p>
    <div class="card fade-up">
      <h2>Download CV</h2>
      <p>Please replace this placeholder with your actual CV file once available.</p>
      <a class="btn" href={`${base}cv.pdf`} target="_blank" rel="noreferrer">Open CV (PDF)</a>
    </div>
  </section>
</BaseLayout>
