---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Pen N" description="Contact Pen N">
  <section class="page">
    <div class="hero">
      <p class="eyebrow fade-up">Contact</p>
      <h1 class="fade-up">Let&apos;s build something useful.</h1>
      <p class="fade-up">
        I&apos;m open to frontend engineering roles and freelance product collaborations.
        The fastest way to reach me is email.
      </p>
    </div>

    <div class="container">
      <div class="grid" style="max-width:74ch;">
        <div class="card fade-up">
          <h2>Connect</h2>
          <p style="margin-bottom: var(--space-lg);">
            Reach out for opportunities, collaborations, or just to say hello.
          </p>
          
          <div class="contact-links">
            <div class="contact-item">
              <strong>Email</strong>
              <a href="mailto:hello@placeholder.dev" class="contact-link">
                hello@placeholder.dev
                <span class="link-indicator">→</span>
              </a>
            </div>
            
            <div class="contact-item">
              <strong>LinkedIn</strong>
              <a href="https://linkedin.com" target="_blank" rel="noreferrer" class="contact-link">
                linkedin.com/in/yourprofile
                <span class="link-indicator">→</span>
              </a>
            </div>
            
            <div class="contact-item">
              <strong>GitHub</strong>
              <a href="https://github.com/pen364692088" target="_blank" rel="noreferrer" class="contact-link">
                github.com/pen364692088
                <span class="link-indicator">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .contact-links {
      display: grid;
      gap: var(--space-md);
    }

    .contact-item {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
      padding: var(--space-sm) 0;
      border-bottom: 1px solid var(--line);
    }

    .contact-item:last-child {
      border-bottom: none;
    }

    .contact-item strong {
      font-family: "Fraunces", "Times New Roman", serif;
      font-size: 1.1rem;
      background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 0.02em;
    }

    .contact-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      color: var(--text-secondary);
      text-decoration: none;
      padding: var(--space-xs) 0;
      transition: all var(--transition-normal) ease;
      position: relative;
      overflow: hidden;
    }

    .contact-link::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 1px;
      background: linear-gradient(90deg, var(--accent), var(--accent-secondary));
      transition: width var(--transition-normal) ease;
    }

    .contact-link:hover {
      color: var(--accent);
      transform: translateX(4px);
    }

    .contact-link:hover::before {
      width: 100%;
    }

    .link-indicator {
      color: var(--accent);
      font-weight: 600;
      transition: all var(--transition-normal) ease;
      opacity: 0;
    }

    .contact-link:hover .link-indicator {
      opacity: 1;
      transform: translateX(4px);
    }

    @media (max-width: 820px) {
      .contact-item {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</BaseLayout>
