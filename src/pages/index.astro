---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith("/") ? baseRaw : `${baseRaw}/`;
---

<BaseLayout title="Pen N | Portfolio" description="Portfolio website for Pen N">
  <section class="hero">
    <p class="eyebrow fade-up">Portfolio</p>
    <h1 class="fade-up">Design-minded developer building calm, effective web experiences.</h1>
    <p class="fade-up">
      I work at the intersection of product strategy, interface design, and frontend engineering.
      My focus is simple: reduce friction, elevate clarity, and ship maintainable solutions that age well.
    </p>
    <div class="fade-up" style="display:flex;gap:.7rem;flex-wrap:wrap;">
      <a class="btn" href={`${base}projects/`}>View projects</a>
      <a class="btn ghost" href={`${base}contact/`}>Get in touch</a>
    </div>
  </section>

  <section class="metrics section-block" aria-label="Experience highlights">
    <div class="metric fade-up"><strong>6+ years</strong><span>Frontend product delivery</span></div>
    <div class="metric fade-up"><strong>20+ launches</strong><span>Across internal and customer-facing tools</span></div>
    <div class="metric fade-up"><strong>Design + code</strong><span>From early concept through implementation</span></div>
  </section>

  <section class="grid two section-block" aria-label="Featured projects">
    <ProjectCard
      title="Operations Dashboard"
      description="A responsive dashboard for field teams with a focus on data clarity, resilient layouts, and accessibility."
      stack="Astro, TypeScript, Chart.js"
    />
    <ProjectCard
      title="Internal Design System"
      description="Built reusable components and contribution guidelines that reduced UI drift and accelerated feature delivery."
      stack="Storybook, CSS, Design Tokens"
    />
  </section>
</BaseLayout>
