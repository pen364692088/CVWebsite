---
interface Props {
  title: string;
  description: string;
  stack: string;
  href?: string;
}

const { title, description, stack, href } = Astro.props;
---

<article class="card fade-up project-card">
  <div class="card-header">
    <h3>{title}</h3>
    <div class="tech-indicator"></div>
  </div>
  <p class="description">{description}</p>
  <p class="stack">{stack}</p>
  {href && (
    <a class="btn ghost" href={href} target="_blank" rel="noreferrer">
      <span class="btn-text">View Project</span>
      <span class="btn-icon">↗</span>
    </a>
  )}
</article>

<style>
  .project-card {
    display: grid;
    gap: var(--space-sm);
    position: relative;
    overflow: hidden;
    transition: all var(--transition-normal) ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 
      0 25px 50px -35px rgba(15, 25, 36, 0.6),
      0 0 30px -8px var(--accent-soft),
      0 0 20px -5px var(--accent-secondary-soft);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .project-card h3 {
    margin-bottom: 0;
    flex: 1;
    background: linear-gradient(135deg, var(--text), var(--accent));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .tech-indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
    box-shadow: 0 0 10px var(--accent-soft);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  .description {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .stack {
    font-size: 0.85rem;
    margin: var(--space-xs) 0 var(--space-md);
    color: var(--muted);
    font-family: monospace;
    background: color-mix(in srgb, var(--surface-hover) 60%, transparent);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    border-left: 2px solid var(--accent);
    position: relative;
  }

  .stack::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 100%;
    background: linear-gradient(to bottom, var(--accent), var(--accent-secondary));
    opacity: 0.7;
    border-radius: 1px;
  }

  .btn {
    position: relative;
    overflow: hidden;
  }

  .btn-text {
    position: relative;
    z-index: 2;
  }

  .btn-icon {
    position: relative;
    z-index: 2;
    transition: transform var(--transition-fast) ease;
  }

  .btn:hover .btn-icon {
    transform: translate(2px, -2px);
  }

  /* Accessibility: reduce motion for users who prefer it */
  @media (prefers-reduced-motion: reduce) {
    .project-card:hover {
      transform: none;
    }
    
    .tech-indicator {
      animation: none;
      opacity: 0.7;
    }
    
    .btn:hover .btn-icon {
      transform: none;
    }
  }
</style>
