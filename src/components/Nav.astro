---
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith("/") ? baseRaw : `${baseRaw}/`;
const links = [
  { path: "", label: "Home" },
  { path: "about/", label: "About" },
  { path: "projects/", label: "Projects" },
  { path: "resume/", label: "Resume" },
  { path: "contact/", label: "Contact" },
];

const withoutBase = Astro.url.pathname.startsWith(base)
  ? Astro.url.pathname.slice(base.length)
  : Astro.url.pathname.replace(/^\//, "");
const currentPath = withoutBase === "" ? "/" : `${withoutBase.replace(/\/$/, "")}/`;
---

<header class="nav-wrap">
  <div class="container nav">
    <a class="brand" href={base}>Pen N</a>
    <nav aria-label="Main navigation">
      <ul>
        {links.map((link) => {
          const href = `${base}${link.path}`;
          const targetPath = link.path === "" ? "/" : `${link.path.replace(/\/$/, "")}/`;
          const active = currentPath === targetPath;
          return (
            <li>
              <a href={href} class={active ? "active" : undefined} aria-current={active ? "page" : undefined}>
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    backdrop-filter: blur(9px);
    background: color-mix(in srgb, #f7f6f3 88%, transparent);
    border-bottom: 1px solid var(--line);
    z-index: 30;
  }

  .nav {
    min-height: 74px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.04em;
    font-size: 0.95rem;
    text-transform: uppercase;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 1.3rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  a {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.94rem;
    transition: color 160ms ease;
  }

  a:hover,
  a.active {
    color: var(--text);
  }

  @media (max-width: 700px) {
    .nav {
      min-height: 62px;
      padding: 0.7rem 0;
      align-items: flex-start;
      flex-direction: column;
    }

    ul {
      gap: 0.9rem;
    }
  }
</style>
