---
const baseRaw = import.meta.env.BASE_URL;
const base = baseRaw.endsWith("/") ? baseRaw : `${baseRaw}/`;
const links = [
  { path: "", label: "Home" },
  { path: "about/", label: "About" },
  { path: "projects/", label: "Projects" },
  { path: "resume/", label: "Resume" },
  { path: "contact/", label: "Contact" },
];

const withoutBase = Astro.url.pathname.startsWith(base)
  ? Astro.url.pathname.slice(base.length)
  : Astro.url.pathname.replace(/^\//, "");
const currentPath = withoutBase === "" ? "/" : `${withoutBase.replace(/\/$/, "")}/`;
---

<header class="nav-wrap">
  <div class="container nav">
    <a class="brand" href={base}>Pen N</a>
    <nav aria-label="Main navigation">
      <ul>
        {links.map((link) => {
          const href = `${base}${link.path}`;
          const targetPath = link.path === "" ? "/" : `${link.path.replace(/\/$/, "")}/`;
          const active = currentPath === targetPath;
          return (
            <li>
              <a href={href} class={active ? "active" : undefined} aria-current={active ? "page" : undefined}>
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--surface) 85%, transparent);
    border-bottom: 1px solid var(--line);
    border-image: linear-gradient(90deg, var(--accent), var(--accent-secondary), var(--accent)) 1;
    box-shadow: 
      0 4px 20px -8px rgba(0, 217, 255, 0.3),
      0 0 0 1px rgba(0, 217, 255, 0.1);
    z-index: 100;
    transition: all var(--transition-normal) ease;
  }

  .nav-wrap:hover {
    box-shadow: 
      0 8px 30px -10px rgba(0, 217, 255, 0.4),
      0 0 0 1px rgba(255, 0, 255, 0.15);
  }

  .nav {
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.05em;
    font-size: 1rem;
    text-transform: uppercase;
    background: linear-gradient(135deg, var(--text), var(--accent));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: relative;
    transition: all var(--transition-normal) ease;
  }

  .brand::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), var(--accent-secondary));
    transition: width var(--transition-normal) ease;
  }

  .brand:hover::after {
    width: 100%;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  li {
    position: relative;
  }

  a {
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.5rem 0.8rem;
    border-radius: var(--radius-sm);
    transition: all var(--transition-normal) ease;
    position: relative;
    overflow: hidden;
  }

  a::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--accent-soft), transparent);
    transition: left var(--transition-slow) ease;
    z-index: -1;
  }

  a:hover::before {
    left: 100%;
  }

  a:hover {
    color: var(--text);
    background: var(--surface-hover);
    box-shadow: 0 0 12px rgba(0, 217, 255, 0.3);
  }

  a.active {
    color: var(--text);
    background: color-mix(in srgb, var(--accent-soft) 30%, transparent);
    box-shadow: 
      inset 0 0 8px rgba(0, 217, 255, 0.2),
      0 0 12px rgba(0, 217, 255, 0.4);
    border: 1px solid rgba(0, 217, 255, 0.3);
  }

  a.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent-secondary));
    border-radius: 1px;
  }

  @media (max-width: 700px) {
    .nav {
      min-height: 70px;
      padding: 0.8rem 0;
      align-items: flex-start;
      flex-direction: column;
      gap: 0.8rem;
    }

    ul {
      gap: 1rem;
      justify-content: flex-start;
      width: 100%;
    }

    a {
      padding: 0.4rem 0.7rem;
      font-size: 0.9rem;
    }

    .brand {
      font-size: 0.9rem;
    }
  }

  /* Accessibility: reduce motion for users who prefer it */
  @media (prefers-reduced-motion: reduce) {
    .nav-wrap,
    a,
    .brand,
    a::before,
    .brand::after,
    a.active::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }
</style>
