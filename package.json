    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.3",
    "linkinator": "^7.6.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
